{
  "name": "lsjm-backend",
  "version": "0.1.0",
  "description": "LSJM backend API - scam risk analysis service",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/server.ts",
    "build": "tsc && tsc-alias -p tsconfig.json && copyfiles -u 1 src/rules/*.json dist",
    "start": "node dist/server.js",
    "data:process": "ts-node -r tsconfig-paths/register src/data/processRiskWords.ts",
    "test": "jest --passWithNoTests",
    "lint": "eslint ."
  },
  "dependencies": {
    "express": "^4.18.2",
    "whoiser": "1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "copyfiles": "^2.4.1",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.8",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  }
}
